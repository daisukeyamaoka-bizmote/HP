---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from './CTAButton.astro';
import Section from './Section.astro';

interface Props {
  pageTitle: string;
  label: string;
  heading: string;
  description?: string;
  accent?: string;
}

const {
  pageTitle,
  label,
  heading,
  description = '',
} = Astro.props;
---

<BaseLayout title={`${pageTitle} | bizmote`}>
  <Section background="white" className="min-h-[70vh]" innerClass="grid max-w-[920px] gap-8">
    <p class="font-mono text-xs leading-relaxed text-noukai">{label}</p>
    <h1 class="font-mincho text-5xl font-normal leading-[1.3]">{heading}</h1>
    {description && <p class="max-w-[620px] text-noukai">{description}</p>}
      <!-- TODO: Replace this restrained placeholder with the finalized page content in a later phase. -->
    <div class="relative min-h-[360px] overflow-hidden border border-tankai bg-kinari" aria-hidden="true">
      <div class="absolute inset-[18px] border border-sumi/10"></div>
      <span class="absolute bottom-5 right-6 font-mono text-[11px] text-noukai">PHASE 1 PLACEHOLDER</span>
    </div>
    <div>
      <CTAButton href="/" variant="text">Back to Top</CTAButton>
    </div>
  </Section>
</BaseLayout>
