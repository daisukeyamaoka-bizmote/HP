---
type BreadcrumbItem = {
  label: string;
  href?: string;
};

interface Props {
  items: BreadcrumbItem[];
  accent?: string;
}

const {
  items,
  accent = 'var(--color-sumi)',
} = Astro.props;
---

<nav class="mb-8 font-mono text-[11px] leading-relaxed text-noukai" aria-label="Breadcrumb" style={`--breadcrumb-accent: ${accent};`}>
  <ol class="flex flex-wrap items-center gap-2">
    {items.map((item, index) => (
      <li class="flex items-center gap-2">
        {item.href ? (
          <a class="outline-none transition-colors hover:text-[var(--breadcrumb-accent)] focus-visible:text-[var(--breadcrumb-accent)]" href={item.href}>
            {item.label}
          </a>
        ) : (
          <span class="text-sumi">{item.label}</span>
        )}
        {index < items.length - 1 && <span aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>
