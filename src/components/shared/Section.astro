---
interface Props {
  id?: string;
  label?: string;
  title?: string;
  titleId?: string;
  headingLevel?: 'h1' | 'h2';
  background?: 'white' | 'kinari';
  className?: string;
  innerClass?: string;
}

const {
  id,
  label,
  title,
  titleId = id ? `${id}-title` : undefined,
  headingLevel = 'h2',
  background = 'white',
  className = '',
  innerClass = '',
} = Astro.props;

const HeadingTag = headingLevel;
const backgroundClass = background === 'kinari' ? 'bg-kinari' : 'bg-white';
---

<section
  id={id}
  class:list={[backgroundClass, 'px-6 py-24 md:px-12 md:py-36 xl:px-16 xl:py-44', className]}
  aria-labelledby={title ? titleId : undefined}
>
  <div class:list={['mx-auto w-full max-w-[1120px]', innerClass]}>
    {label && <p class="mb-6 text-sm leading-relaxed text-noukai">{label}</p>}
    {title && (
      <HeadingTag id={titleId} class="max-w-[900px] font-mincho text-[42px] font-normal leading-[1.35] md:text-[58px] xl:text-[66px]">
        {title}
      </HeadingTag>
    )}
    <slot />
  </div>
</section>
