---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/shared/CTAButton.astro';
import HorizontalRail from '../../components/shared/HorizontalRail.astro';
import Section from '../../components/shared/Section.astro';

const shipNavItems = [
  { label: 'ABOUT', href: '#about' },
  { label: 'TARGET', href: '#target' },
  { label: 'PEOPLE', href: '#people' },
  { label: 'EXPERIENCE', href: '#experience' },
  { label: 'SERVICE', href: '#service' },
  { label: 'PROCESS', href: '#process' },
  { label: 'KNOWLEDGE', href: '#knowledge' },
  { label: 'CONTACT', href: '#contact' },
];

const targetCards = [
  {
    title: '起業したいが、実践経験がまだ足りない',
    body: 'アイデアや意欲はあるが、顧客と向き合い、提案し、商談を進める経験をもっと積みたい人。',
  },
  {
    title: 'BtoB営業を現場で学びたい',
    body: '法人営業、顧客理解、提案、商談設計を、座学ではなく実際の案件を通じて学びたい人。',
  },
  {
    title: '実践を通じて収入や経験を増やしたい',
    body: '次の挑戦に向けて、現場経験を積みながら、収入や資金づくりにもつなげたい人。',
  },
  {
    title: '仲間やつながりを増やしたい',
    body: '同じように起業を目指す人や、事業の現場で動く人たちと出会い、視野を広げたい人。',
  },
];

type MemberProfile = {
  category: 'intern' | 'freelance';
  name: string;
  image?: string;
  title: string;
  interests: string[];
  reason: string;
  activities: string;
  comment: string;
};

const memberProfiles: MemberProfile[] = [
  {
    category: 'intern',
    name: '山田 太郎',
    title: '〇〇大学 3年',
    interests: ['スタートアップ', 'BtoB営業', 'AI'],
    reason: '将来起業したいと思い、実際の事業づくりに近い環境で学びたかった。',
    activities: '市場リサーチ、ターゲット企業調査、GTM案件の運用補助',
    comment: '知識だけではなく、現場で考える力を身につけたいです。',
  },
  {
    category: 'intern',
    name: '鈴木 美咲',
    title: '〇〇大学 2年',
    interests: ['新規事業', 'コミュニティ', '採用'],
    reason: '起業に向けて、同じ温度で動く仲間と出会える環境に身を置きたかった。',
    activities: 'イベント運営、参加者ヒアリング、コミュニティ企画',
    comment: '挑戦している人の近くで、自分の視野を広げていきたいです。',
  },
  {
    category: 'intern',
    name: '高橋 蓮',
    title: '〇〇大学 4年',
    interests: ['SaaS', '営業企画', '事業づくり'],
    reason: '就職前にBtoB営業の現場を経験し、事業を売る感覚を持ちたかった。',
    activities: '営業リスト作成、商談準備、顧客課題の整理',
    comment: '机上の学びを、顧客と向き合う経験に変えていきたいです。',
  },
  {
    category: 'freelance',
    name: '佐藤 花子',
    title: 'マーケティング / リサーチ',
    interests: ['BtoBマーケティング', '営業資料', 'スタートアップ支援'],
    reason: 'スタートアップ支援の現場に関わりながら、事業づくりの経験を増やしたかった。',
    activities: 'ABM施策、営業リスト作成、提案資料作成',
    comment: '信頼できる仲間と、長く一緒に仕事ができる場だと感じています。',
  },
  {
    category: 'freelance',
    name: '中村 健',
    title: '営業 / 事業開発',
    interests: ['BtoB営業', '事業開発', 'コミュニティ'],
    reason: '個人で動きながらも、事業の現場に深く関われる接点を増やしたかった。',
    activities: '初期営業、商談同席、営業プロセスの整理',
    comment: 'ひとりでは得にくい学びや機会が、自然に集まる場所です。',
  },
  {
    category: 'freelance',
    name: '小林 彩',
    title: 'デザイン / コンテンツ',
    interests: ['ブランド設計', 'コンテンツ', '事業づくり'],
    reason: '次の挑戦を見据えて、営業や事業づくりの近くで自分の専門性を磨きたかった。',
    activities: 'サービス資料、記事企画、コミュニティ発信',
    comment: '違う専門性の人と関わることで、自分の挑戦も具体的になっていきます。',
  },
];

const internProfiles = memberProfiles.filter((profile) => profile.category === 'intern');
const freelanceProfiles = memberProfiles.filter((profile) => profile.category === 'freelance');

const experienceCards = [
  {
    name: 'SALES PRACTICE',
    title: 'BtoB営業の実践を積む',
    body: '実際の商材や営業テーマに触れながら、顧客理解、アプローチ、商談、振り返りまで経験します。',
  },
  {
    name: 'NEXT STEP',
    title: '次の挑戦を具体にする',
    body: '事業アイデア、顧客課題、売り方、お金のつくり方を、実践を通じて少しずつ具体化します。',
  },
  {
    name: 'COMMUNITY',
    title: '仲間とつながる',
    body: '起業に関心がある人、BtoB営業を学びたい人、スタートアップに関わりたい人がつながる場をつくります。',
  },
];

const services = [
  {
    area: 'BtoB営業実践',
    support: '法人向けの営業活動を通じて、顧客理解、仮説立て、提案、商談の経験を積みます。',
    output: '営業経験 / 顧客理解',
  },
  {
    area: '実践コミュニティ',
    support: '起業に関心がある人、BtoB営業を学びたい人、スタートアップに関わりたい人が集まる場をつくります。',
    output: '仲間 / 情報交換',
  },
  {
    area: '収入・資金づくり',
    support: '実践機会を通じて、次の挑戦に向けた収入や資金づくりへつなげます。',
    output: '実践機会 / 資金づくり',
  },
  {
    area: '壁打ち・メンタリング',
    support: '事業アイデア、キャリア、営業の振り返りについて、前に進むための整理を行います。',
    output: '論点整理 / 次の行動',
  },
  {
    area: 'つながりづくり',
    support: '起業家、事業会社、同じ志向を持つ仲間との接点を増やし、挑戦の選択肢を広げます。',
    output: '接点 / 協力機会',
  },
];

const processSteps = [
  {
    title: '参加する',
    body: '今の関心、経験、学びたいことを整理し、参加の目的を明確にします。',
    output: '目的整理',
  },
  {
    title: '営業を学ぶ',
    body: 'BtoB営業の基本、顧客理解、商談の流れを学び、実践に入る準備をします。',
    output: '営業基礎',
  },
  {
    title: '実践する',
    body: '実際の営業活動を通じて、顧客の反応、提案の難しさ、商談の手触りを経験します。',
    output: '実践経験',
  },
  {
    title: '振り返る',
    body: 'うまくいったこと、詰まったこと、次に試すことを整理し、学びを積み上げます。',
    output: '学習ログ',
  },
  {
    title: '次につなげる',
    body: '得た経験、資金、人とのつながりを、次の挑戦や事業づくりへつなげます。',
    output: '次の一歩',
  },
];

const knowledgeNotes = [
  {
    title: 'BtoB営業を経験する意味',
    body: '顧客の課題を聞き、価値を届け、対価を得る経験は、事業づくりの基礎になる。',
    meta: 'SALES',
  },
  {
    title: '次の挑戦までの時間を、ただの待ち時間にしない',
    body: '学ぶ、売る、貯める、つながる。その時間をどう使うかで、次の一歩は変わる。',
    meta: 'PREP',
  },
  {
    title: '仲間がいると、挑戦は続きやすくなる',
    body: '同じ方向を向く人との壁打ちや情報交換が、孤独な準備期間を前に進める。',
    meta: 'COMMUNITY',
  },
  {
    title: '営業経験は、事業アイデアを強くする',
    body: '顧客と話すことで、机上の仮説が現実の課題や購買行動に近づいていく。',
    meta: 'STARTUP',
  },
];
---

<BaseLayout
  title="bizShip | 挑戦の準備を、現場で進める。"
  description="bizShipは、学生や社会人がBtoB営業の実践を積み、収入や資金、人とのつながりをつくるコミュニティサービスです。起業に関心がある人、スタートアップに関わりたい人、事業づくりを現場で学びたい人が集まります。"
  navItems={shipNavItems}
  showServicesMenu={false}
  navAriaLabel="bizShip section navigation"
>
  <section class="min-h-[calc(100vh-72px)] bg-white px-6 py-16 md:min-h-[calc(100vh-80px)] md:px-12 md:py-24 xl:px-16 xl:py-28" aria-labelledby="ship-title">
    <div class="mx-auto flex min-h-[calc(100vh-220px)] w-full max-w-[1180px] items-center">
      <div class="max-w-[980px]">
        <p class="mb-8 font-cormorant text-[34px] leading-none text-[var(--color-ship-deep)]">bizShip</p>
        <h1 class="font-mincho text-[56px] font-medium leading-[1.08] md:text-[100px] xl:text-[124px]" id="ship-title">
          挑戦の準備を<br />
          現場で進める
        </h1>
        <p class="mt-10 max-w-3xl font-mincho text-[27px] leading-[1.75] md:text-[34px]">
          BtoB営業を実践しながら、<br />
          経験、収入、仲間、次の選択肢をつくる。
        </p>
        <div class="mt-10">
          <CTAButton href="/contact/?service=ship" className="bg-[var(--color-ship-deep)] hover:bg-sumi">
            参加について相談したい
          </CTAButton>
        </div>
      </div>
    </div>
  </section>

  <Section id="about" background="kinari" label="ABOUT" title="次の挑戦に向けて、実践で進める。">
    <p class="mt-8 max-w-[800px] text-[17px] leading-[2] text-noukai">
      bizShipは、BtoB営業を現場で学びたい学生や社会人のためのコミュニティサービスです。<br />
      実践を積みながら、収入や資金をつくり、
      人とのつながりを増やし、次の挑戦に向けた準備を進めていきます。
    </p>
  </Section>

  <Section id="target" background="white" label="TARGET" title="実践しながら、次の挑戦を探している人へ。">
    <p class="mt-8 max-w-[760px] text-[17px] leading-[2] text-noukai">
      bizShipが向き合うのは、次の挑戦がまだ定まりきっていない時期です。<br />
      起業するか決めきれていなくても、顧客と向き合う経験、人とのつながり、資金づくりは始められます。
    </p>

    <div class="mt-12 grid gap-px bg-tankai md:grid-cols-2">
      {targetCards.map((card, index) => (
        <article class="grid min-h-[250px] content-between bg-white p-6">
          <div>
            <p class="font-mono text-xs text-[var(--color-ship-deep)]">{String(index + 1).padStart(2, '0')}</p>
            <h2 class="mt-7 font-mincho text-[28px] font-medium leading-[1.45]">{card.title}</h2>
            <p class="mt-5 text-[14px] leading-[1.9] text-noukai">{card.body}</p>
          </div>
        </article>
      ))}
    </div>
  </Section>

  <Section id="people" background="kinari" label="PEOPLE" title="学生も、社会人も。挑戦の形はひとつじゃない。">
    <p class="mt-8 max-w-[860px] text-[17px] leading-[2] text-noukai">
      bizShipには、起業を目指す学生、スタートアップの現場に関わるインターン、
      フリーランスとして力を磨く社会人など、さまざまな挑戦者が集まります。<br />
      立場は違っても、自分で考え、動き、事業づくりに向き合う意思を持った人たちです。
    </p>

    <div class="mt-16">
      <div class="flex items-end justify-between gap-6 border-b border-tankai pb-5">
        <h2 class="font-mono text-xs font-normal text-[var(--color-ship-deep)]">INTERNS</h2>
        <p class="text-right text-[13px] leading-relaxed text-noukai">学生 / 実践経験 / 事業づくり</p>
      </div>
      <div class="mt-6 grid gap-px bg-tankai md:grid-cols-3">
        {internProfiles.map((profile) => (
          <article class="grid min-h-[560px] content-between bg-white p-5">
            <div>
              {profile.image ? (
                <img class="h-48 w-full object-cover" src={profile.image} alt={`${profile.name}の写真`} />
              ) : (
                <div class="flex h-48 w-full items-center justify-center bg-kinari" aria-label={`${profile.name}の写真プレースホルダー`}>
                  <span class="font-cormorant text-[54px] leading-none text-noukai">{profile.name.slice(0, 1)}</span>
                </div>
              )}
              <p class="mt-6 font-mincho text-[28px] font-medium leading-[1.35]">{profile.name}</p>
              <p class="mt-2 font-mono text-xs leading-relaxed text-noukai">{profile.title}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {profile.interests.map((interest) => (
                  <span class="rounded-full border border-tankai px-3 py-1 font-mono text-[11px] leading-relaxed text-noukai">{interest}</span>
                ))}
              </div>
              <dl class="mt-6 grid gap-5 text-[13px] leading-[1.85] text-noukai">
                <div>
                  <dt class="font-mono text-[11px] text-[var(--color-ship-deep)]">WHY</dt>
                  <dd class="mt-2">{profile.reason}</dd>
                </div>
                <div>
                  <dt class="font-mono text-[11px] text-[var(--color-ship-deep)]">WORK</dt>
                  <dd class="mt-2">{profile.activities}</dd>
                </div>
              </dl>
            </div>
            <p class="mt-8 border-t border-tankai pt-5 font-mincho text-[20px] leading-[1.65]">{profile.comment}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="mt-20">
      <div class="flex items-end justify-between gap-6 border-b border-tankai pb-5">
        <h2 class="font-mono text-xs font-normal text-[var(--color-ship-deep)]">FREELANCE</h2>
        <p class="text-right text-[13px] leading-relaxed text-noukai">社会人 / 専門性 / スタートアップ接点</p>
      </div>
      <div class="mt-6 grid gap-px bg-tankai md:grid-cols-3">
        {freelanceProfiles.map((profile) => (
          <article class="grid min-h-[560px] content-between bg-white p-5">
            <div>
              {profile.image ? (
                <img class="h-48 w-full object-cover" src={profile.image} alt={`${profile.name}の写真`} />
              ) : (
                <div class="flex h-48 w-full items-center justify-center bg-kinari" aria-label={`${profile.name}の写真プレースホルダー`}>
                  <span class="font-cormorant text-[54px] leading-none text-noukai">{profile.name.slice(0, 1)}</span>
                </div>
              )}
              <p class="mt-6 font-mincho text-[28px] font-medium leading-[1.35]">{profile.name}</p>
              <p class="mt-2 font-mono text-xs leading-relaxed text-noukai">{profile.title}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {profile.interests.map((interest) => (
                  <span class="rounded-full border border-tankai px-3 py-1 font-mono text-[11px] leading-relaxed text-noukai">{interest}</span>
                ))}
              </div>
              <dl class="mt-6 grid gap-5 text-[13px] leading-[1.85] text-noukai">
                <div>
                  <dt class="font-mono text-[11px] text-[var(--color-ship-deep)]">WHY</dt>
                  <dd class="mt-2">{profile.reason}</dd>
                </div>
                <div>
                  <dt class="font-mono text-[11px] text-[var(--color-ship-deep)]">WORK</dt>
                  <dd class="mt-2">{profile.activities}</dd>
                </div>
              </dl>
            </div>
            <p class="mt-8 border-t border-tankai pt-5 font-mincho text-[20px] leading-[1.65]">{profile.comment}</p>
          </article>
        ))}
      </div>
    </div>

    <p class="mt-16 max-w-[760px] border-t border-tankai pt-10 text-[17px] leading-[2] text-noukai">
      肩書きや年齢よりも、自分で考え、動き、挑戦に向き合う姿勢を大切にしています。<br />
      bizShipは、そんな人たちが出会い、学び、次の一歩をつくる場所です。
    </p>
  </Section>

  <Section id="experience" background="kinari" label="EXPERIENCE" title="営業実践、資金づくり、仲間づくりをひとつに。">
    <HorizontalRail ariaLabel="bizShip experience layers">
      {experienceCards.map((card) => (
        <article class="grid min-h-[340px] w-[82vw] max-w-[420px] flex-none snap-start content-between border border-tankai bg-white p-6 transition-colors hover:border-[var(--color-ship-deep)] md:w-[360px]">
          <div>
            <p class="font-mono text-xs text-[var(--color-ship-deep)]">{card.name}</p>
            <h2 class="mt-8 font-mincho text-[31px] font-medium leading-[1.45]">{card.title}</h2>
            <p class="mt-5 text-[15px] leading-[1.9] text-noukai">{card.body}</p>
          </div>
        </article>
      ))}
    </HorizontalRail>
  </Section>

  <Section id="service" background="white" label="SERVICE" title="bizShipでできること">
    <p class="mt-8 max-w-[760px] text-[17px] leading-[2] text-noukai">
      次の挑戦に必要な力を、実践の中で少しずつ積み上げます。<br />
      営業実践、資金づくり、壁打ち、つながりづくりを一体で進めます。
    </p>

    <div class="mt-12 overflow-x-auto border border-tankai bg-white">
      <table class="min-w-[860px] table-fixed text-left">
        <caption class="sr-only">bizShipでできること一覧</caption>
        <thead>
          <tr class="border-b border-tankai">
            <th class="w-[25%] px-6 py-5 font-mono text-xs font-normal text-[var(--color-ship-deep)]" scope="col">SERVICE</th>
            <th class="w-[51%] px-6 py-5 font-mono text-xs font-normal text-[var(--color-ship-deep)]" scope="col">SUPPORT</th>
            <th class="w-[24%] px-6 py-5 font-mono text-xs font-normal text-[var(--color-ship-deep)]" scope="col">OUTPUT</th>
          </tr>
        </thead>
        <tbody>
          {services.map((service) => (
            <tr class="border-b border-tankai last:border-b-0">
              <th class="px-6 py-6 align-top font-mincho text-[23px] font-medium leading-[1.45]" scope="row">{service.area}</th>
              <td class="px-6 py-6 align-top text-[14px] leading-[1.9] text-noukai">{service.support}</td>
              <td class="px-6 py-6 align-top font-mono text-xs leading-[1.8] text-noukai">{service.output}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Section>

  <Section id="process" background="kinari" label="PROCESS" title="次の挑戦を、実践で具体にする">
    <p class="mt-8 max-w-[760px] text-[17px] leading-[2] text-noukai">
      bizShipは、学ぶだけのコミュニティではありません。<br />
      実際に動き、顧客と向き合い、振り返り、次の挑戦に向けた材料を増やしていきます。
    </p>

    <ol class="mt-12 grid gap-px bg-tankai md:grid-cols-5">
      {processSteps.map((step, index) => (
        <li class="grid min-h-[280px] content-between bg-white p-6">
          <div>
            <span class="font-mono text-xs text-[var(--color-ship-deep)]">{String(index + 1).padStart(2, '0')}</span>
            <p class="mt-8 font-mincho text-[25px] leading-[1.45]">{step.title}</p>
            <p class="mt-5 text-[13px] leading-[1.9] text-noukai">{step.body}</p>
          </div>
          <p class="mt-8 border-t border-tankai pt-4 font-mono text-xs text-noukai">{step.output}</p>
        </li>
      ))}
    </ol>

    <div class="mt-16 border border-tankai bg-white p-6 md:p-8">
      <div class="grid gap-6 md:grid-cols-[1fr_auto_1fr_auto_1fr_auto_1fr] md:items-center">
        <div>
          <span class="font-mono text-xs text-[var(--color-ship-deep)]">01</span>
          <p class="mt-4 font-mincho text-[28px] leading-[1.35]">学ぶ</p>
          <p class="mt-3 text-[13px] leading-[1.8] text-noukai">BtoB営業の基礎を知る</p>
        </div>
        <div class="hidden h-px w-12 bg-[var(--color-ship-deep)] md:block"></div>
        <div>
          <span class="font-mono text-xs text-[var(--color-ship-deep)]">02</span>
          <p class="mt-4 font-mincho text-[28px] leading-[1.35]">売る</p>
          <p class="mt-3 text-[13px] leading-[1.8] text-noukai">顧客と向き合い実践する</p>
        </div>
        <div class="hidden h-px w-12 bg-[var(--color-ship-deep)] md:block"></div>
        <div>
          <span class="font-mono text-xs text-[var(--color-ship-deep)]">03</span>
          <p class="mt-4 font-mincho text-[28px] leading-[1.35]">貯める</p>
          <p class="mt-3 text-[13px] leading-[1.8] text-noukai">収入や資金づくりにつなげる</p>
        </div>
        <div class="hidden h-px w-12 bg-[var(--color-ship-deep)] md:block"></div>
        <div>
          <span class="font-mono text-xs text-[var(--color-ship-deep)]">04</span>
          <p class="mt-4 font-mincho text-[28px] leading-[1.35]">つながる</p>
          <p class="mt-3 text-[13px] leading-[1.8] text-noukai">仲間や機会を増やす</p>
        </div>
      </div>
    </div>
  </Section>

  <Section id="knowledge" background="white" label="KNOWLEDGE" title="現場で磨いた実践ナレッジ">
    <p class="mt-8 max-w-[680px] text-[17px] leading-[2] text-noukai">
      BtoB営業、資金づくり、仲間づくり、事業づくりの現場で見えてきた論点を、実践に使える知見としてNotesに残していきます。
    </p>

    <HorizontalRail ariaLabel="bizShip knowledge notes">
      {knowledgeNotes.map((note) => (
        <a
          href="/notes/?category=bizShip"
          class="group grid min-h-[310px] w-[82vw] max-w-[430px] flex-none snap-start content-between border border-tankai bg-white p-6 text-sumi transition-colors hover:border-[var(--color-ship-deep)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-ship-deep)] md:w-[360px]"
        >
          <div>
            <!-- TODO: Replace these static cards with Notes CMS content. -->
            <p class="font-mono text-xs text-[var(--color-ship-deep)]">STARTUP KNOWLEDGE / {note.meta}</p>
            <h2 class="mt-8 font-mincho text-[29px] font-medium leading-[1.45]">{note.title}</h2>
            <p class="mt-5 text-[14px] leading-[1.9] text-noukai">{note.body}</p>
          </div>
          <p class="mt-8 font-mono text-xs text-noukai transition-colors group-hover:text-[var(--color-ship-deep)]">
            READ KNOWLEDGE
          </p>
        </a>
      ))}
    </HorizontalRail>
  </Section>

  <Section id="contact" background="kinari" label="CONTACT" title="まずは、興味がある段階からご相談ください">
    <p class="mt-8 max-w-[680px] text-[17px] leading-[2] text-noukai">
      起業するか決めきれていなくても構いません。<br />
      BtoB営業を実践したい、スタートアップの現場に関わりたい、仲間を増やしたい。
      そんな段階から話せます。
    </p>
    <div class="mt-10">
      <CTAButton href="/contact/?service=ship" className="bg-[var(--color-ship-deep)] hover:bg-sumi">
        参加について相談したい
      </CTAButton>
    </div>
  </Section>
</BaseLayout>
