---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/shared/Breadcrumbs.astro';
import CTAButton from '../../components/shared/CTAButton.astro';
import LocalNav from '../../components/shared/LocalNav.astro';
import RelatedServices from '../../components/shared/RelatedServices.astro';
import ResponsiveTable from '../../components/shared/ResponsiveTable.astro';
import Section from '../../components/shared/Section.astro';
import SummaryCards from '../../components/shared/SummaryCards.astro';
import ThreeColumnFlow from '../../components/shared/ThreeColumnFlow.astro';

const shipLocalNavItems = [
  { label: 'できること', href: '#value' },
  { label: '参加条件', href: '#value' },
  { label: '参加者', href: '#people' },
  { label: '出口', href: '#exit' },
  { label: '応募する', href: '#contact' },
];

const relatedServices = [
  {
    name: 'bizFlag',
    body: 'BtoB企業の売れる条件を見つけるGTM/ABM支援',
    href: '/flag/',
    accent: 'var(--color-flag-base)',
  },
  {
    name: 'bizLab',
    body: '社内で試したAI活用を、現場で使える仕組みにするラボ',
    href: '/lab/',
    accent: 'var(--color-lab-deep)',
  },
];

const shipSummary = [
  {
    label: 'FOR',
    title: '起業したい社会人・学生',
    body: '事業アイデアが固まる前でも、次の挑戦を探している段階から参加できます。',
  },
  {
    label: 'STYLE',
    title: '無料・審査制',
    body: '参加費は無料。場の熱量を守るため、応募内容をもとに参加可否を確認します。',
  },
  {
    label: 'VALUE',
    title: '学び・仲間・実践',
    body: '壁打ち、勉強会、交流、GTM案件への参加機会を通じて視野を広げます。',
  },
  {
    label: 'NEXT',
    title: '出口はひとつじゃない',
    body: '起業、スタートアップ転職、フリーランス、共同プロジェクトなどにつなげます。',
  },
];

const shipOverview = [
  {
    label: 'INPUT',
    title: '参加前の状態',
    items: ['起業に関心がある', '仲間や壁打ち相手が少ない', '実践の場がほしい', '次の挑戦を探している'],
  },
  {
    label: 'bizShip',
    title: '提供する場',
    items: ['学びと勉強会', 'VC/CVC壁打ち', '西新宿オフィス', 'GTM案件への接点'],
  },
  {
    label: 'OUTPUT',
    title: '生まれる次の一歩',
    items: ['起業準備が具体になる', '仲間と出会う', 'キャリアの選択肢が広がる', '共同プロジェクトが生まれる'],
  },
];

const communityNodes = [
  {
    label: 'LEARN',
    title: '学び',
    body: '事業づくり、GTM、資金調達、チームづくりの考え方を知る。',
  },
  {
    label: 'PEERS',
    title: '仲間との出会い',
    body: '同じように挑戦したい人と出会い、相談できる関係をつくる。',
  },
  {
    label: 'VC / CVC',
    title: '壁打ち',
    body: '投資家視点で、事業アイデアや仮説を見直す機会をつくる。',
  },
  {
    label: 'OFFICE',
    title: '西新宿オフィス',
    body: '作業、交流、ミーティング、勉強会の場所として使える。',
  },
  {
    label: 'PROJECT',
    title: 'GTM案件',
    body: '希望や適性に応じて、スタートアップの現場に触れる。',
  },
  {
    label: 'EXIT',
    title: '次の出口',
    body: '起業、転職、フリーランス、共同プロジェクトへ進む。',
  },
];

const participationRows = [
  { item: '参加費', detail: '無料' },
  { item: '参加形式', detail: '審査制' },
  { item: '主な対象', detail: '社会人 / 学生' },
  { item: '提供価値', detail: '学び / 仲間 / 実践 / 壁打ち' },
  { item: '参加方法', detail: '応募フォームから申し込み' },
];

const targetCards = [
  {
    title: '起業したいが、まだ一人で動いている',
    body: '事業アイデアや関心領域はあるが、壁打ちできる仲間や実践の場がまだ少ない人。',
  },
  {
    title: '学生のうちから事業づくりに触れたい',
    body: 'インターンやプロジェクトを通じて、スタートアップの現場やBtoB事業の考え方を学びたい人。',
  },
  {
    title: '社会人として次の挑戦を探している',
    body: '仕事を続けながら、起業、フリーランス、スタートアップ転職など次の選択肢を広げたい人。',
  },
  {
    title: '同じ熱量の仲間と出会いたい',
    body: 'アイデア相談、チームづくり、共同プロジェクトのきっかけになる関係をつくりたい人。',
  },
];

const valueCards = [
  {
    label: 'FREE / SCREENED',
    title: '参加は無料・審査制',
    body: '参加費は無料です。ただし、場の熱量を守るため、応募内容をもとに簡単な審査を行います。',
  },
  {
    label: 'VC / CVC',
    title: '投資家視点で壁打ちする',
    body: '事業アイデアや仮説を、VC・CVCなどの投資家視点で壁打ちできる機会があります。資金調達を保証するものではなく、視点を広げる機会です。',
  },
  {
    label: 'FOUNDERS',
    title: '起業家同士でつながる',
    body: '同じように挑戦したい仲間と出会い、アイデア相談、チームづくり、共同プロジェクトのきっかけをつくります。',
  },
  {
    label: 'OFFICE',
    title: '西新宿オフィスを使える',
    body: 'bizmoteの西新宿オフィスを、作業、壁打ち、ミーティング、勉強会、交流の場として利用できます。',
  },
  {
    label: 'GTM PROJECT',
    title: 'スタートアップGTM案件に触れる',
    body: '希望や適性に応じて、bizmoteが支援するスタートアップのGTM案件に関われる可能性があります。案件を保証するものではなく、実践機会として提供します。',
  },
];

type MemberProfile = {
  category: 'intern' | 'freelance';
  name: string;
  image?: string;
  title: string;
  interests: string[];
  reason: string;
  activities: string;
  comment: string;
};

const showMemberProfiles = true;

const memberProfiles: MemberProfile[] = [
  {
    category: 'intern',
    name: '掲載準備中 01',
    title: 'インターン生 / 学生',
    interests: ['スタートアップ', 'BtoB営業', 'AI'],
    reason: '将来起業したいと思い、実際の事業づくりに近い環境で学びたかった。',
    activities: '市場リサーチ、ターゲット企業調査、GTM案件の運用補助',
    comment: '知識だけではなく、現場で考える力を身につけたいです。',
  },
  {
    category: 'intern',
    name: '掲載準備中 02',
    title: 'インターン生 / 学生',
    interests: ['新規事業', 'コミュニティ', '採用'],
    reason: '同じ温度で動く仲間と出会える環境に身を置きたかった。',
    activities: 'イベント運営、参加者ヒアリング、コミュニティ企画',
    comment: '挑戦している人の近くで、自分の視野を広げていきたいです。',
  },
  {
    category: 'intern',
    name: '掲載準備中 03',
    title: 'インターン生 / 学生',
    interests: ['SaaS', '営業企画', '事業づくり'],
    reason: '就職前にBtoB事業の現場を経験し、事業を前に進める感覚を持ちたかった。',
    activities: '営業リスト作成、商談準備、顧客課題の整理',
    comment: '机上の学びを、顧客と向き合う経験に変えていきたいです。',
  },
  {
    category: 'freelance',
    name: '掲載準備中 04',
    title: 'フリーランス / マーケティング',
    interests: ['BtoBマーケティング', '営業資料', 'スタートアップ支援'],
    reason: 'スタートアップ支援の現場に関わりながら、事業づくりの経験を増やしたかった。',
    activities: 'ABM施策、営業リスト作成、提案資料作成',
    comment: '信頼できる仲間と、長く一緒に仕事ができる場だと感じています。',
  },
  {
    category: 'freelance',
    name: '掲載準備中 05',
    title: 'フリーランス / 事業開発',
    interests: ['BtoB営業', '事業開発', 'コミュニティ'],
    reason: '個人で動きながらも、事業の現場に深く関われる接点を増やしたかった。',
    activities: '初期営業、商談同席、営業プロセスの整理',
    comment: 'ひとりでは得にくい学びや機会が、自然に集まる場所です。',
  },
  {
    category: 'freelance',
    name: '掲載準備中 06',
    title: 'フリーランス / コンテンツ',
    interests: ['ブランド設計', 'コンテンツ', '事業づくり'],
    reason: '次の挑戦を見据えて、事業づくりの近くで自分の専門性を磨きたかった。',
    activities: 'サービス資料、記事企画、コミュニティ発信',
    comment: '違う専門性の人と関わることで、自分の挑戦も具体的になっていきます。',
  },
];

const internProfiles = memberProfiles.filter((profile) => profile.category === 'intern');
const freelanceProfiles = memberProfiles.filter((profile) => profile.category === 'freelance');

const participantGroups = [
  {
    label: 'INTERNS',
    title: 'インターン生',
    body: '起業に関心がある学生や、スタートアップの現場で実践経験を積みたい学生が参加します。',
  },
  {
    label: 'FREELANCE',
    title: 'フリーランス・社会人',
    body: '専門性を持ちながら、次の挑戦や事業づくりへの接点を増やしたい社会人が参加します。',
  },
  {
    label: 'FOUNDERS',
    title: '起業準備中の人',
    body: '事業アイデアを壁打ちし、仲間やプロジェクトと出会いながら次の一歩を具体にします。',
  },
];

const flowSteps = [
  {
    title: '応募する',
    body: '関心領域、今の活動、参加したい理由を簡単に共有してください。',
    output: 'ENTRY',
  },
  {
    title: '審査する',
    body: '場の熱量を守るため、応募内容をもとに参加可否を確認します。',
    output: 'SCREENING',
  },
  {
    title: '参加する',
    body: '西新宿オフィスやオンラインで、壁打ち、勉強会、交流に参加できます。',
    output: 'COMMUNITY',
  },
  {
    title: '機会に触れる',
    body: '希望や適性に応じて、GTM案件やスタートアップの現場に関わる機会があります。',
    output: 'PROJECT',
  },
  {
    title: '次へ進む',
    body: '起業、転職、フリーランス、共同プロジェクトなど、自分に合う出口を探します。',
    output: 'NEXT STEP',
  },
];

const exitCards = [
  {
    title: '起業する',
    body: '会社設立や事業立ち上げに向けた準備、GTM設計、専門家との接続など、創業初期の一歩を支援します。',
  },
  {
    title: 'スタートアップへ飛び込む',
    body: 'プロジェクトを通じて出会ったスタートアップとの接点が、将来の転職やキャリアにつながることもあります。',
  },
  {
    title: 'フリーランスとして挑戦する',
    body: '希望や適性に応じて、bizmoteや支援先のGTMプロジェクトで継続的に協働する機会があります。',
  },
  {
    title: '仲間と事業をつくる',
    body: '同じ志を持つ仲間と出会い、事業アイデアの壁打ちや共同プロジェクトが生まれる場をつくります。',
  },
];

---

<BaseLayout
  title="bizShip | 起業したい人の無料・審査制コミュニティ"
  description="bizShipは、起業したい社会人・学生が集まり、学び、実践し、仲間と次の一歩をつくる無料・審査制コミュニティです。VC・CVCとの壁打ち、西新宿オフィス、GTM案件への参加機会を提供します。"
>
  <section class="min-h-[calc(100vh-72px)] bg-white px-6 py-16 md:min-h-[calc(100vh-80px)] md:px-12 md:py-24 xl:px-16 xl:py-28" aria-labelledby="ship-title">
    <div class="mx-auto grid min-h-[calc(100vh-220px)] w-full max-w-[1180px] items-center gap-12 lg:grid-cols-[minmax(0,0.95fr)_minmax(360px,0.55fr)]">
      <div>
        <Breadcrumbs
          accent="var(--color-ship-deep)"
          items={[
            { label: 'Top', href: '/' },
            { label: 'Services', href: '/#services' },
            { label: 'bizShip' },
          ]}
        />
        <p class="mb-8 font-cormorant text-[34px] leading-none text-[var(--color-ship-deep)]">bizShip</p>
        <h1 class="font-mincho text-[58px] font-medium leading-[1.08] md:text-[104px] xl:text-[126px]" id="ship-title">
          孤独から、<br />
          仲間へ。
        </h1>
        <p class="mt-10 max-w-3xl font-mincho text-[25px] leading-[1.75] md:text-[32px]">
          起業したい社会人・学生が集まり、学び、実践し、次の一歩をつくる無料・審査制コミュニティです。
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          {['参加費無料', '審査制', '社会人・学生歓迎'].map((item) => (
            <span class="rounded-full border border-tankai px-4 py-2 font-mono text-xs text-noukai">{item}</span>
          ))}
        </div>
        <div class="mt-10 flex flex-wrap gap-4">
          <CTAButton href="#value" className="bg-[var(--color-ship-deep)] hover:bg-sumi">
            参加条件を見る
          </CTAButton>
          <CTAButton href="#value" variant="text" className="text-[var(--color-ship-deep)] hover:text-sumi">
            できることを見る
          </CTAButton>
        </div>
      </div>
      <div class="border border-tankai bg-kinari p-5" aria-label="bizShip network diagram">
        <div class="grid gap-px bg-tankai sm:grid-cols-2">
          {communityNodes.map((node) => (
            <div class="min-h-[130px] bg-white p-4">
              <p class="font-mono text-[11px] text-[var(--color-ship-deep)]">{node.label}</p>
              <p class="mt-5 font-mincho text-[24px] leading-[1.35]">{node.title}</p>
            </div>
          ))}
        </div>
        <div class="mt-5 border border-tankai bg-white p-5 text-center">
          <p class="font-cormorant text-[44px] leading-none text-[var(--color-ship-deep)]">bizShip</p>
          <p class="mt-3 font-mono text-[11px] leading-relaxed text-noukai">LEARN / PEERS / PROJECT / EXIT</p>
        </div>
      </div>
    </div>
  </section>

  <LocalNav items={shipLocalNavItems} accent="var(--color-ship-deep)" ariaLabel="bizShip page navigation" />

  <section id="overview" class="border-y border-tankai bg-white px-6 py-10 md:px-12 xl:px-16" aria-labelledby="ship-overview-title">
    <div class="mx-auto w-full max-w-[1120px]">
      <h2 id="ship-overview-title" class="sr-only">bizShipの一目でわかる要約</h2>
      <SummaryCards items={shipSummary} accent="var(--color-ship-deep)" />
    </div>
  </section>

  <Section id="about" background="kinari" label="ABOUT" title="起業したい人が、仲間と出会う場所。">
    <p class="mt-8 max-w-[820px] text-[17px] leading-[2] text-noukai">
      起業は、ひとりで始めるには孤独です。<br />
      bizShipは、起業したい社会人・学生が集まり、事業づくりを学び、実際のプロジェクトに触れ、仲間と次の一歩をつくるコミュニティです。
    </p>
    <p class="mt-10 max-w-[820px] border-t border-tankai pt-8 font-mincho text-[30px] leading-[1.55] md:text-[42px]">
      知識は手に入りやすくなった。だからこそ、誰と挑むかが問われる。
    </p>
    <ThreeColumnFlow
      className="mt-12"
      ariaLabel="bizShip community overview"
      columns={shipOverview}
      accent="var(--color-ship-deep)"
    />
  </Section>

  <Section id="target" background="white" label="TARGET" title="こんな人に向いています">
    <div class="grid gap-px bg-tankai md:grid-cols-2">
      {targetCards.map((card, index) => (
        <article class="grid min-h-[250px] content-between bg-white p-6">
          <div>
            <p class="font-mono text-xs text-[var(--color-ship-deep)]">{String(index + 1).padStart(2, '0')}</p>
            <h2 class="mt-7 font-mincho text-[28px] font-medium leading-[1.45]">{card.title}</h2>
            <p class="mt-5 text-[14px] leading-[1.9] text-noukai">{card.body}</p>
          </div>
        </article>
      ))}
    </div>
  </Section>

  <Section id="value" background="white" label="VALUE" title="無料で参加し、仲間と事業の近くに入る。">
    <p class="mt-8 max-w-[760px] text-[17px] leading-[2] text-noukai">
      bizShipは、誰でも入れる軽い場ではありません。<br />
      参加費は無料。ただし、挑戦に向き合う人が安心して動けるよう、応募内容をもとに審査を行います。
    </p>

    <div class="mt-12">
      <h3 class="font-mincho text-[34px] font-medium leading-[1.45] md:text-[42px]">bizShipでできること</h3>
      <div class="mt-8 grid gap-px bg-tankai md:grid-cols-3">
        {communityNodes.slice(0, 3).map((node) => (
          <article class="min-h-[230px] bg-white p-6">
            <p class="font-mono text-xs text-[var(--color-ship-deep)]">{node.label}</p>
            <h4 class="mt-7 font-mincho text-[28px] font-medium leading-[1.45]">{node.title}</h4>
            <p class="mt-4 text-[14px] leading-[1.9] text-noukai">{node.body}</p>
          </article>
        ))}
        <article class="grid min-h-[210px] content-center bg-[var(--color-ship-deep)] p-6 text-white md:col-span-3">
          <p class="font-cormorant text-[52px] leading-none">bizShip</p>
          <p class="mt-5 font-mincho text-[25px] leading-[1.45]">仲間と次の一歩をつくる場</p>
        </article>
        {communityNodes.slice(3).map((node) => (
          <article class="min-h-[230px] bg-white p-6">
            <p class="font-mono text-xs text-[var(--color-ship-deep)]">{node.label}</p>
            <h4 class="mt-7 font-mincho text-[28px] font-medium leading-[1.45]">{node.title}</h4>
            <p class="mt-4 text-[14px] leading-[1.9] text-noukai">{node.body}</p>
          </article>
        ))}
      </div>
    </div>

    <ResponsiveTable
      className="mt-12"
      caption="bizShipの参加条件"
      accent="var(--color-ship-deep)"
      headers={[
        { key: 'item', label: '項目' },
        { key: 'detail', label: '内容', muted: true },
      ]}
      rows={participationRows}
    />

    <div class="mt-12 border-t border-tankai pt-10">
      <p class="font-mincho text-[30px] leading-[1.5] md:text-[40px]">参加の前提を見たうえで、興味があれば応募へ。</p>
      <div class="mt-8">
        <CTAButton href="/contact/?service=ship" className="bg-[var(--color-ship-deep)] hover:bg-sumi">
          コミュニティ参加について見る
        </CTAButton>
      </div>
    </div>

    <div class="mt-12 grid gap-px bg-tankai md:grid-cols-2 xl:grid-cols-3">
      {valueCards.map((card, index) => (
        <article class="grid min-h-[300px] content-between bg-white p-6">
          <div>
            <p class="font-mono text-xs text-[var(--color-ship-deep)]">{card.label}</p>
            <h2 class="mt-8 font-mincho text-[29px] font-medium leading-[1.45]">{card.title}</h2>
            <p class="mt-5 text-[14px] leading-[1.9] text-noukai">{card.body}</p>
          </div>
          <p class="mt-8 border-t border-tankai pt-4 font-mono text-xs text-noukai">{String(index + 1).padStart(2, '0')}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section id="people" background="kinari" label="PEOPLE" title="学生も、社会人も。挑戦の形はひとつじゃない。">
    <p class="mt-8 max-w-[860px] text-[17px] leading-[2] text-noukai">
      bizShipには、起業を目指す学生、スタートアップの現場に関わるインターン、
      フリーランスとして力を磨く社会人など、さまざまな挑戦者が集まります。<br />
      立場は違っても、自分で考え、動き、事業づくりに向き合う意思を大切にします。
    </p>

    {showMemberProfiles ? (
      <>
        <h3 class="mt-16 font-mono text-xs font-normal text-[var(--color-ship-deep)]">インターン生</h3>
        <div class="mt-6 grid gap-px bg-tankai md:grid-cols-3">
          {internProfiles.map((profile) => (
            <article class="grid min-h-[520px] content-between bg-white p-5">
              <div>
                <div class="flex h-44 w-full items-center justify-center bg-kinari" aria-label={`${profile.name}の写真プレースホルダー`}>
                  <span class="font-cormorant text-[54px] leading-none text-noukai">{profile.name.slice(0, 1)}</span>
                </div>
                <p class="mt-6 font-mincho text-[28px] font-medium leading-[1.35]">{profile.name}</p>
                <p class="mt-2 font-mono text-xs leading-relaxed text-noukai">{profile.title}</p>
                <dl class="mt-6 grid gap-4 text-[13px] leading-[1.85] text-noukai">
                  <div>
                    <dt class="font-mono text-[11px] text-[var(--color-ship-deep)]">目指していること</dt>
                    <dd class="mt-1">{profile.reason}</dd>
                  </div>
                  <div>
                    <dt class="font-mono text-[11px] text-[var(--color-ship-deep)]">関わっていること</dt>
                    <dd class="mt-1">{profile.activities}</dd>
                  </div>
                </dl>
              </div>
              <p class="mt-8 border-t border-tankai pt-5 font-mincho text-[20px] leading-[1.65]">{profile.comment}</p>
            </article>
          ))}
        </div>
        <h3 class="mt-12 font-mono text-xs font-normal text-[var(--color-ship-deep)]">フリーランス</h3>
        <div class="mt-6 grid gap-px bg-tankai md:grid-cols-3">
          {freelanceProfiles.map((profile) => (
            <article class="grid min-h-[520px] content-between bg-white p-5">
              <div>
                <div class="flex h-44 w-full items-center justify-center bg-kinari" aria-label={`${profile.name}の写真プレースホルダー`}>
                  <span class="font-cormorant text-[54px] leading-none text-noukai">{profile.name.slice(0, 1)}</span>
                </div>
                <p class="mt-6 font-mincho text-[28px] font-medium leading-[1.35]">{profile.name}</p>
                <p class="mt-2 font-mono text-xs leading-relaxed text-noukai">{profile.title}</p>
                <dl class="mt-6 grid gap-4 text-[13px] leading-[1.85] text-noukai">
                  <div>
                    <dt class="font-mono text-[11px] text-[var(--color-ship-deep)]">目指していること</dt>
                    <dd class="mt-1">{profile.reason}</dd>
                  </div>
                  <div>
                    <dt class="font-mono text-[11px] text-[var(--color-ship-deep)]">関わっていること</dt>
                    <dd class="mt-1">{profile.activities}</dd>
                  </div>
                </dl>
              </div>
              <p class="mt-8 border-t border-tankai pt-5 font-mincho text-[20px] leading-[1.65]">{profile.comment}</p>
            </article>
          ))}
        </div>
      </>
    ) : (
      <div class="mt-12 grid gap-px bg-tankai md:grid-cols-3">
        {participantGroups.map((group) => (
          <article class="grid min-h-[260px] content-between bg-white p-6">
            <div>
              <p class="font-mono text-xs text-[var(--color-ship-deep)]">{group.label}</p>
              <h2 class="mt-8 font-mincho text-[30px] font-medium leading-[1.45]">{group.title}</h2>
              <p class="mt-5 text-[14px] leading-[1.9] text-noukai">{group.body}</p>
            </div>
          </article>
        ))}
      </div>
    )}

    <p class="mt-12 max-w-[760px] border-t border-tankai pt-8 text-[15px] leading-[1.9] text-noukai">
      参加者プロフィールは、本人確認と掲載許可が取れたものから公開します。
      写真と実名は、公開許諾後に差し替えます。
    </p>
  </Section>

  <Section id="flow" background="kinari" label="FLOW" title="応募から参加まで">
    <p class="mt-8 max-w-[760px] text-[17px] leading-[2] text-noukai">
      参加前に、今の関心や活動内容を確認します。<br />
      参加後は、交流、壁打ち、勉強会、実践機会を通じて、次の一歩を探します。
    </p>

    <ol class="mt-12 grid gap-px bg-tankai md:grid-cols-5">
      {flowSteps.map((step, index) => (
        <li class="grid min-h-[280px] content-between bg-white p-6">
          <div>
            <span class="font-mono text-xs text-[var(--color-ship-deep)]">{String(index + 1).padStart(2, '0')}</span>
            <p class="mt-8 font-mincho text-[25px] leading-[1.45]">{step.title}</p>
            <p class="mt-5 text-[13px] leading-[1.9] text-noukai">{step.body}</p>
          </div>
          <p class="mt-8 border-t border-tankai pt-4 font-mono text-xs text-noukai">{step.output}</p>
        </li>
      ))}
    </ol>
  </Section>

  <Section id="exit" background="white" label="EXIT" title="挑戦の出口は、ひとつじゃない。">
    <p class="mt-8 max-w-[760px] text-[17px] leading-[2] text-noukai">
      bizShipのゴールは、全員を同じ形にすることではありません。<br />
      起業、転職、フリーランス、共同プロジェクトなど、その人に合う次の一歩をつくります。
    </p>

    <div class="mt-12 grid gap-px bg-tankai md:grid-cols-2">
      {exitCards.map((card, index) => (
        <article class="grid min-h-[250px] content-between bg-white p-6">
          <div>
            <p class="font-mono text-xs text-[var(--color-ship-deep)]">EXIT {String(index + 1).padStart(2, '0')}</p>
            <h2 class="mt-8 font-mincho text-[30px] font-medium leading-[1.45]">{card.title}</h2>
            <p class="mt-5 text-[14px] leading-[1.9] text-noukai">{card.body}</p>
          </div>
        </article>
      ))}
    </div>
  </Section>

  <Section id="philosophy" background="kinari" label="PHILOSOPHY" title="知識は手に入りやすくなった。だからこそ、誰と挑むかが問われる。">
    <div class="mt-10 grid gap-px bg-tankai md:grid-cols-3">
      {[
        { label: 'KNOWLEDGE', text: '知識は、検索やAIで手に入りやすくなった。' },
        { label: 'PEERS', text: 'それでも、壁打ちできる仲間や現場の接点は自然には増えない。' },
        { label: 'ACTION', text: 'bizShipは、人と実践の近くで次の一歩をつくる場です。' },
      ].map((item) => (
        <article class="bg-white p-6">
          <p class="font-mono text-xs text-[var(--color-ship-deep)]">{item.label}</p>
          <p class="mt-8 font-mincho text-[26px] leading-[1.5]">{item.text}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section id="contact" background="white" label="CONTACT" title="まずは、参加してみませんか。">
    <p class="mt-8 max-w-[700px] text-[17px] leading-[2] text-noukai">
      参加費無料 / 審査制 / 社会人・学生歓迎
    </p>
    <div class="mt-10">
      <CTAButton href="/contact/?service=ship" className="bg-[var(--color-ship-deep)] hover:bg-sumi">
        bizShipに応募する
      </CTAButton>
    </div>
  </Section>

  <RelatedServices services={relatedServices} />
</BaseLayout>
