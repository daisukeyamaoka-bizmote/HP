---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HorizontalRail from '../../components/shared/HorizontalRail.astro';
import NoteCard from '../../components/shared/NoteCard.astro';
import Section from '../../components/shared/Section.astro';
import { categories, notes } from '../../data/notes';

const featuredNotes = notes.filter((note) => note.featured);
---

<BaseLayout
  title="Notes | bizmote"
  description="bizmoteのNotesでは、GTM、コミュニティ、AI活用、会社づくりの現場で得た知見を、次の挑戦につながるナレッジとして記録します。"
>
  <section class="min-h-[calc(100vh-72px)] bg-white px-6 py-16 md:min-h-[calc(100vh-80px)] md:px-12 md:py-24 xl:px-16 xl:py-28" aria-labelledby="notes-title">
    <div class="mx-auto flex min-h-[calc(100vh-220px)] w-full max-w-[1180px] items-center">
      <div class="max-w-[980px]">
        <p class="mb-8 font-cormorant text-[34px] leading-none text-noukai">Notes</p>
        <h1 class="font-mincho text-[56px] font-medium leading-[1.08] md:text-[100px] xl:text-[124px]" id="notes-title">
          現場から<br />
          次を考える
        </h1>
        <p class="mt-10 max-w-3xl font-mincho text-[27px] leading-[1.75] md:text-[34px]">
          GTM、コミュニティ、AI活用、会社づくり。<br />
          実践の中で得た知見を、次の挑戦につながるナレッジとして残します。
        </p>
      </div>
    </div>
  </section>

  <Section background="kinari" label="FEATURED" title="まず読んでほしいナレッジ">
    <HorizontalRail ariaLabel="Featured notes list">
      {featuredNotes.map((note) => (
        <NoteCard note={note} variant="rail" showTags={false} />
      ))}
    </HorizontalRail>
  </Section>

  <Section background="white" label="ARCHIVE" title="カテゴリから探す">
    <div class="mt-8 flex flex-wrap gap-3" aria-label="Notes category filters">
      {categories.map((category) => (
        <a
          href={category.href}
          data-note-filter={category.id}
          class="rounded-full border border-tankai px-4 py-2 font-mono text-xs leading-relaxed text-sumi outline-none transition-colors hover:border-sumi focus-visible:ring-2 focus-visible:ring-sumi focus-visible:ring-offset-4"
        >
          {category.label}
        </a>
      ))}
    </div>

    <p class="mt-8 font-mono text-xs text-noukai" data-note-result>
      ALL KNOWLEDGE
    </p>

    <div class="mt-8 grid gap-px bg-tankai md:grid-cols-2 xl:grid-cols-3">
      {notes.map((note) => (
        <NoteCard note={note} variant="grid" filterable />
      ))}
    </div>
  </Section>

  <Section background="kinari" label="PURPOSE" title="完成された答えより、現場で見えたことを。">
    <p class="mt-8 max-w-[760px] text-[17px] leading-[2] text-noukai">
      Notesは、完成された答えを並べる場所ではありません。<br />
      仮説を市場に出すこと、仲間と挑戦を続けること、AIを現場で使うこと、
      会社を育てること。その途中で得た知見を、次の行動につながる形で残していきます。
    </p>
  </Section>

  <script>
    const initNotesFilter = () => {
      const validCategories = ['all', 'bizFlag', 'bizShip', 'bizLab', 'bizmote'];
      const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-note-card]'));
      const filters = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-note-filter]'));
      const result = document.querySelector<HTMLElement>('[data-note-result]');

      const getCategoryFromUrl = () => {
        const category = new URLSearchParams(window.location.search).get('category') ?? 'all';
        return validCategories.includes(category) ? category : 'all';
      };

      const setFilter = (category: string) => {
        const selected = validCategories.includes(category) ? category : 'all';
        let visibleCount = 0;

        cards.forEach((card) => {
          const isVisible = selected === 'all' || card.dataset.category === selected;
          card.hidden = !isVisible;
          if (isVisible) visibleCount += 1;
        });

        filters.forEach((filter) => {
          const isActive = filter.dataset.noteFilter === selected;
          filter.classList.toggle('bg-sumi', isActive);
          filter.classList.toggle('text-white', isActive);
          filter.classList.toggle('border-sumi', isActive);
          filter.setAttribute('aria-current', isActive ? 'true' : 'false');
        });

        if (result) {
          result.textContent = selected === 'all' ? `ALL KNOWLEDGE / ${visibleCount}` : `${selected} / ${visibleCount}`;
        }
      };

      filters.forEach((filter) => {
        filter.addEventListener('click', (event) => {
          const url = new URL(filter.href);
          if (url.pathname !== window.location.pathname) return;

          event.preventDefault();
          const selected = url.searchParams.get('category') ?? 'all';
          const nextCategory = validCategories.includes(selected) ? selected : 'all';
          const nextUrl = nextCategory === 'all' ? window.location.pathname : `${window.location.pathname}?category=${nextCategory}`;

          history.pushState(null, '', nextUrl);
          setFilter(nextCategory);
        });
      });

      window.addEventListener('popstate', () => {
        setFilter(getCategoryFromUrl());
      });

      setFilter(getCategoryFromUrl());
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initNotesFilter, { once: true });
    } else {
      initNotesFilter();
    }
  </script>
</BaseLayout>
